# Frontend environment variables
# Copy this file to .env.local for local development

# Backend API base URL
VITE_SERVER_URL=http://localhost:3000/api/v1

# Frontend base URL
VITE_BASE_URL=http://localhost:5173

# Backend WebSocket URL
VITE_SERVER_WS_URL=ws://localhost:3000

# --- PRODUCTION values (set these in Vercel Dashboard, not here) ---
# VITE_SERVER_URL=https://<your-render-app>.onrender.com/api/v1
# VITE_BASE_URL=https://<your-vercel-app>.vercel.app
# VITE_SERVER_WS_URL=wss://<your-render-app>.onrender.com
